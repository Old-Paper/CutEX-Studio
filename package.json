{
  "name": "cutex-studio",
  "version": "0.7.0",
  "description": "Local-first automatic rough cut tool for voice-over media",
  "main": "dist/main/index.js",
  "author": "CutEX Studio",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.4.3",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "studio.cutex.app",
    "productName": "CutEX Studio",
    "electronDist": "node_modules/electron/dist",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "package.json"],
    "win": { "target": ["portable"], "artifactName": "CutEX-Studio-${version}-Windows.${ext}" }
  }
}
